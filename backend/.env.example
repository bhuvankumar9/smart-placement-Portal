# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local example:
# MONGO_URI=mongodb://localhost:27017/nits
# MongoDB Atlas example (recommended — free tier, already a replica set
# so transactions in studentController.js work without extra setup):
MONGO_URI=mongodb+srv://user:Passw0rd.@cluster0.3xy0j1t.mongodb.net/?appName=nits-dashboard&retryWrites=true&w=majority

# ─── Redis (Local) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Admin setup ──────────────────────────────────────────
ADMIN_SETUP_KEY=replace-with-a-secret-setup-key
OTP_TTL_SECONDS=300

# ─── CORS — Frontend URL ──────────────────────────────────
CLIENT_URLS=http://localhost:5173

# ─── Email (Brevo SMTP) ───────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=af58df001@smtp-brevo.com
BREVO_SMTP_KEY=YOUR_BREVO_SMTP_KEY
BREVO_SENDER_EMAIL=your-email@gmail.com
BREVO_SENDER_NAME=NITS Dashboard
